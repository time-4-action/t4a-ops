# /etc/t4a-backup.env — config for backup.sh
# Deploy to /etc/t4a-backup.env, chmod 600, chown root:root.
# This file is sourced by bash, so arrays work; do not switch to KEY=val only.

# Restic repo on Hetzner Storage Box. Path is relative to the SSH user's
# home directory — no leading slash, no "/./" (that's rsync syntax, not
# restic; restic treats "/./path" as absolute and fails on locked-down
# hosts like Hetzner Storage Box).
RESTIC_REPOSITORY="sftp:t4a-storagebox:restic/t4a-t2"

# File containing the restic repo password. Root-only, chmod 600.
# Losing this file = losing access to every backup. Store a copy off-server
# in a password manager.
RESTIC_PASSWORD_FILE="/root/.restic-password"

# Host label stored inside each snapshot. Keeps snapshots separable if you
# ever point more servers at the same repo.
BACKUP_HOST="t4a-t2"

BACKUP_PATHS_WORDPRESS=(
  /mnt/vdc/www/t4a
)

BACKUP_PATHS_CONFIGS=(
  /etc/nginx
  /etc/letsencrypt
  /etc/my.cnf.d
  /etc/fstab
  /etc/hosts
  /etc/systemd/system/t4a-backup.service
  /etc/systemd/system/t4a-backup.timer
  /etc/systemd/system/t4a-backup-maintenance.service
  /etc/systemd/system/t4a-backup-maintenance.timer
  # Add docker-compose directories and their .env files here, e.g.:
  # /opt/docker/patrik
  # /opt/docker/n8n
  # /opt/docker/t4a-platform
  # /opt/docker/t4a-mcp
  # /opt/docker/certbot
)
