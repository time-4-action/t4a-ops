# /etc/t4a-backup.env — config for backup.sh
# Deploy to /etc/t4a-backup.env, chmod 600, chown root:root.
# This file is sourced by bash, so arrays work; do not switch to KEY=val only.

# Restic repo on Hetzner Storage Box. Path is relative to the SSH user's
# home directory — no leading slash, no "/./" (that's rsync syntax, not
# restic; restic treats "/./path" as absolute and fails on locked-down
# hosts like Hetzner Storage Box).
RESTIC_REPOSITORY="sftp:t4a-storagebox:restic/t4a-t2"

# File containing the restic repo password. Root-only, chmod 600.
# Losing this file = losing access to every backup. Store a copy off-server
# in a password manager.
RESTIC_PASSWORD_FILE="/root/.restic-password"

# Host label stored inside each snapshot. Keeps snapshots separable if you
# ever point more servers at the same repo.
BACKUP_HOST="t4a-t2"

BACKUP_PATHS_WORDPRESS=(
  /mnt/vdc/www/t4a
)

# n8n — name of the PostgreSQL container (see docker/t4a-t2/n8n/docker-compose.yaml).
# backup.sh runs `docker exec $N8N_POSTGRES_CONTAINER pg_dump ...` so the container
# must be up when the backup runs. Creds are read from the container's own env
# (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB), populated by /data/n8n/.env.
N8N_POSTGRES_CONTAINER="n8n_postgres"

# MongoDB — bare-metal, auth enabled. URI must include credentials.
# Create a dedicated backup user: db.createUser({user:"backup",pwd:"...",roles:["backup"]})
# Then set: MONGO_URI="mongodb://backup:PASSWORD@localhost:27017"
MONGO_URI="mongodb://backup:CHANGE_ME@localhost:27017"

# n8n filesystem paths — workflow definitions, credentials (encrypted at rest
# with N8N_ENCRYPTION_KEY from /data/n8n/.env), and files uploaded via workflows.
# Restoring only the Postgres dump is NOT enough; n8n_data holds config + secrets.
BACKUP_PATHS_N8N=(
  /data/n8n/n8n_data
  /data/n8n/local-files
)

BACKUP_PATHS_CONFIGS=(
  # --- System-level configs ---
  /etc/nginx
  /etc/letsencrypt
  /etc/my.cnf.d
  /etc/mongod.conf
  /etc/fstab
  /etc/hosts
  /etc/systemd/system/t4a-backup.service
  /etc/systemd/system/t4a-backup.timer
  /etc/systemd/system/t4a-backup-maintenance.service
  /etc/systemd/system/t4a-backup-maintenance.timer

  # --- Docker compose stacks ---
  # Explicit list of compose files + their secret envs. Bare-metal recovery
  # needs BOTH the compose YAML (image refs + wiring) AND the .env (creds),
  # or services won't start. Service DATA (SQLite, ChromaDB, Postgres DB,
  # WordPress) is handled by dedicated tags or is a known gap —
  # see docs/runbooks/backup-coverage.md for the full map.

  # Patrik stack (patrik-api, patrik-products-automation, patrik-products-ui)
  /data/patrik/docker-compose.yaml
  /data/patrik/.env

  # n8n stack (compose only — n8n_data/.env contents are already covered by n8n-files tag)
  /data/n8n/docker-compose.yaml
  /data/n8n/.env

  # T4A platform stacks
  /data/stack/apps/time-4-action/admin/docker-compose.yaml
  /data/stack/apps/time-4-action/admin/.env.local
  /data/stack/apps/time-4-action/chat/docker-compose.yaml
  /data/stack/apps/time-4-action/chat/.env.local
  /data/stack/apps/time-4-action/export/docker-compose.yaml
  /data/stack/apps/time-4-action/export/.env
  /data/stack/apps/time-4-action/mcp/docker-compose.yaml
  /data/stack/apps/time-4-action/mcp/.env
  # sync compose has no env_file reference at time of writing; add /data/stack/apps/time-4-action/sync/.env here if that changes.
  /data/stack/apps/time-4-action/sync/docker-compose.yaml

  # Certbot — uncomment once you confirm the exact filenames on the server.
  # /data/certbot/docker-compose.yaml
  # /data/certbot/.env
)
